<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipe_refresh_home"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/AxiformaLight"
    android:background="#0D0D0D">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <ImageView
                android:id="@+id/img_top_banner"
                android:background="@drawable/bg_home_top"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:scaleType="centerCrop"
                app:layout_constraintTop_toTopOf="parent" />

            <FrameLayout
                android:id="@+id/custom_images_container"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:clipChildren="true"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/island_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                android:background="@drawable/bg_home_island"
                android:orientation="vertical"
                android:paddingTop="32dp"
                app:layout_constraintTop_toBottomOf="@+id/img_top_banner">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:theme="@style/AxiformaSemiBold"
                    android:text="Status"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="24dp">

                    <androidx.constraintlayout.widget.Group
                        android:id="@+id/group_offline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:constraint_referenced_ids="card_my_avatar_offline, card_friend_avatar_offline, card_sleeping_badge"
                        tools:visibility="visible" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_my_avatar_offline"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        app:cardBackgroundColor="#1A1A1A"
                        app:cardCornerRadius="30dp"
                        app:strokeColor="#66FF99"
                        app:strokeWidth="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">


                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/img_my_avatar_offline"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:background="#2E1A47"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_friend_avatar_offline"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginStart="24dp"
                        app:cardBackgroundColor="#1A1A1A"
                        app:cardCornerRadius="30dp"
                        app:strokeColor="#FF6B6B"
                        app:strokeWidth="2dp"
                        app:layout_constraintStart_toEndOf="@id/card_my_avatar_offline"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/img_friend_avatar_offline"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:background="#E5D9C5"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_sleeping_badge"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        app:cardBackgroundColor="#2A2A2A"
                        app:cardCornerRadius="13dp"
                        app:strokeWidth="0dp"
                        android:elevation="8dp"
                        app:layout_constraintBottom_toBottomOf="@id/card_friend_avatar_offline"
                        app:layout_constraintEnd_toEndOf="@id/card_friend_avatar_offline"
                        android:layout_marginEnd="-6dp"
                        android:layout_marginBottom="0dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="😴"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:paddingBottom="-2dp"/>
                    </com.google.android.material.card.MaterialCardView>

                    <androidx.constraintlayout.widget.Group
                        android:id="@+id/group_playing"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:constraint_referenced_ids="card_status_avatars, img_status_vinyl, card_status_song, img_note_top, img_note_bottom" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_status_avatars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#1A1A1A"
                        app:cardCornerRadius="40dp"
                        app:strokeColor="#66FF99"
                        app:strokeWidth="2dp"
                        app:cardElevation="4dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="2dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/img_status_my_avatar"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:background="#2E1A47"
                                android:scaleType="centerCrop"
                                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent" />

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/img_status_friend_avatar"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:layout_marginStart="-20dp"
                                android:background="#E5D9C5"
                                android:scaleType="centerCrop"
                                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                                app:layout_constraintStart_toEndOf="@id/img_status_my_avatar"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/img_status_vinyl"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="-26dp"
                        android:background="#121212"
                        android:src="@drawable/vinyl"
                        android:elevation="2dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        app:layout_constraintStart_toEndOf="@id/card_status_avatars"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_status_song"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="-20dp"
                        app:cardBackgroundColor="#4F4F4F"
                        app:cardCornerRadius="18dp"
                        app:strokeWidth="0dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toEndOf="@id/img_status_vinyl"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="26dp"
                            android:paddingEnd="12dp">

                            <TextView
                                android:id="@+id/tv_status_now_playing"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:singleLine="true"
                                android:ellipsize="end"
                                android:text="Carregando..."
                                android:textColor="#FFFFFF"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <ImageView
                        android:id="@+id/img_note_top"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:rotation="15"
                        android:src="@drawable/nota_musical"
                        app:tint="#66FF99"
                        android:elevation="1dp"
                        app:layout_constraintStart_toEndOf="@+id/img_status_vinyl"
                        app:layout_constraintBottom_toTopOf="@+id/img_status_vinyl"
                        android:translationX="14dp"
                        android:translationY="14dp" />

                    <ImageView
                        android:id="@+id/img_note_bottom"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:rotation="-15"
                        android:src="@drawable/nota_musical"
                        app:tint="#66FF99"
                        android:elevation="5dp"
                        app:layout_constraintEnd_toStartOf="@+id/img_status_vinyl"
                        app:layout_constraintTop_toBottomOf="@+id/img_status_vinyl"
                        android:translationX="46dp"
                        android:translationY="-14dp" />

                </androidx.constraintlayout.widget.ConstraintLayout>
                <LinearLayout
                    android:id="@+id/header_playlists"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Playlists"
                        android:textColor="#FFFFFF"
                        android:theme="@style/AxiformaSemiBold"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/next_icon"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_home_playlists"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:orientation="horizontal" />

                <LinearLayout
                    android:id="@+id/header_all_songs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Todas as musicas"
                        android:theme="@style/AxiformaSemiBold"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/next_icon"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_home_songs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:orientation="horizontal" />

            </LinearLayout>

            <View
                android:id="@+id/top_glow_effect"
                android:layout_width="match_parent"
                android:layout_height="700dp"
                android:background="@drawable/generic_top_glow_effect"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginTop="40dp"
                android:layout_marginEnd="16dp"
                android:padding="14dp"
                android:src="@android:drawable/ic_menu_manage"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:translationZ="90dp"
                app:tint="#FFFFFF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>