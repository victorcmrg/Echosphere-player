<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:theme="@style/AxiformaLight"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/img_playlist_cover"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:background="#9B5EF9" />

    <ImageView
        android:id="@+id/img_fallback_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_media_play"
        android:visibility="gone"
        app:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="@id/img_playlist_cover"
        app:layout_constraintEnd_toEndOf="@id/img_playlist_cover"
        app:layout_constraintStart_toStartOf="@id/img_playlist_cover"
        app:layout_constraintTop_toTopOf="@id/img_playlist_cover" />

    <TextView
        android:id="@+id/tv_playlist_initials"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/img_playlist_cover"
        app:layout_constraintEnd_toEndOf="@id/img_playlist_cover"
        app:layout_constraintStart_toStartOf="@id/img_playlist_cover"
        app:layout_constraintTop_toTopOf="@id/img_playlist_cover"
        tools:text="PL"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tv_playlist_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:theme="@style/AxiformaSemiBold"
        android:layout_marginEnd="58dp"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1"
        app:layout_constraintBottom_toTopOf="@id/tv_playlist_count"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/img_playlist_cover"
        app:layout_constraintTop_toTopOf="@id/img_playlist_cover"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="Minha Playlist" />

    <TextView
        android:id="@+id/tv_playlist_count"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="#808080"
        android:layout_marginEnd="60dp"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@id/img_playlist_cover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/img_playlist_cover"
        app:layout_constraintTop_toBottomOf="@id/tv_playlist_name"
        tools:text="12 músicas" />


</androidx.constraintlayout.widget.ConstraintLayout>